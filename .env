# ============================================================
# TuniERP — Docker Environment Variables
# ============================================================
# Copy this file to .env in the root directory:
#   cp .env.docker.example .env
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=tunierp
POSTGRES_PASSWORD=tunierp_secret_change_me
POSTGRES_DB=tunierp
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────
REDIS_PORT=6379

# ── JWT Authentication ─────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── General ────────────────────────────────────────────────
NODE_ENV=production

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_VERSION=v2.0.0
NEXT_PUBLIC_API_HOST=http://localhost:4060
NEXT_PUBLIC_METADATA_BASE=https://tunierp.tn
